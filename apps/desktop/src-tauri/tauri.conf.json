{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Movie App",
  "version": "1.0.13",
  "identifier": "com.movie.app.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter @movie-app/desktop dev",
    "beforeBuildCommand": "pnpm --filter @movie-app/desktop build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Movie App",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src * data: blob: ws: wss:; script-src * 'unsafe-inline'; style-src * 'unsafe-inline'; img-src * data:; connect-src *;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
